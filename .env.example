# Aegis Environment Variables

# Block explorer API keys (for fetching verified contract source code)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# RPC endpoints (defaults to public RPCs if not set)
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Private key for contract deployment (DO NOT commit this file with a real key)
PRIVATE_KEY=

# Attester private key - used by MCP server to sign attestations
# Must match the `attester` address in the deployed contracts
# Falls back to PRIVATE_KEY if not set (same key for deploy + attest)
ATTESTER_PRIVATE_KEY=

# Wallet address (derived from PRIVATE_KEY)
WALLET_ADDRESS=

# Fee recipient - where protocol fees are sent (IMMUTABLE after deploy)
# Use a Safe multisig (app.safe.global) for production, NOT a single EOA
# If you lose access to this address, fees are locked forever
FEE_RECIPIENT=

# Solodit API key - cross-references scan findings against 50K+ real audit findings
# Get your key at solodit.cyfrin.io (profile > API Keys)
# Rate limit: 20 requests per 60-second window
SOLODIT_API_KEY=

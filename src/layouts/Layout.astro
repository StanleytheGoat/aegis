---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalUrl = "https://aegis-defi.netlify.app",
  ogImage = "https://aegis-defi.netlify.app/og.png",
} = Astro.props;
---

<html class="dark" lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="DeFi, security, MCP, AI agents, Ethereum, Base, smart contract, honeypot, rug pull, Uniswap">
  <meta name="author" content="Aegis">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl}>
  <link rel="apple-touch-icon" href="/og.png">
  <link rel="manifest" href="/manifest.json">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content="Scan contracts for exploit patterns, simulate transactions on forked chains, and enforce safety on-chain. One MCP command to protect your agent.">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Aegis">
  <meta property="og:locale" content="en_US">
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content="Scan contracts for exploit patterns, simulate transactions on forked chains, and enforce safety on-chain.">
  <meta name="twitter:image" content={ogImage}>

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z' fill='%23070d1f' stroke='%23ffe792' stroke-width='2'/></svg>">

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Aegis",
    "description": "DeFi safety layer for autonomous AI agents. MCP server that scans contracts, simulates transactions, and enforces on-chain protection.",
    "applicationCategory": "DeveloperApplication",
    "applicationSubCategory": "DeFi Security",
    "operatingSystem": "Any",
    "softwareVersion": "0.5.0",
    "url": "https://aegis-defi.netlify.app",
    "license": "https://opensource.org/licenses/MIT",
    "programmingLanguage": ["TypeScript", "Solidity"],
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Aegis" }
  }
  </script>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
</head>

<body class="selection:bg-primary selection:text-on-primary-fixed">
  <slot />
</body>
</html>

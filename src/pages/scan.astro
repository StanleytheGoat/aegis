---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="Scan Contract - Aegis"
  description="Paste a contract address and get an instant safety verdict. Checks for exploit patterns, honeypot mechanics, and simulation results."
  canonicalUrl="https://aegis-defi.netlify.app/scan"
>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-surface-dim/70 backdrop-blur-xl" aria-label="Main navigation">
    <div class="flex justify-between items-center px-8 py-4 max-w-screen-xl mx-auto relative">
      <a href="/" class="flex items-center gap-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="glow-gold" aria-hidden="true">
          <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" fill="#070d1f" stroke="#ffe792" stroke-width="1.5"/>
          <path d="M9 12l2 2 4-4" stroke="#ffe792" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-xl font-black tracking-tight text-on-surface font-headline">Aegis</span>
      </a>
      <a href="/" class="text-on-surface-variant hover:text-on-surface transition-colors font-label text-[10px] uppercase tracking-widest">Back to Home</a>
    </div>
  </nav>

  <main class="pt-28 pb-24 px-8 max-w-screen-md mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-label text-[10px] uppercase tracking-[0.3em] mb-4">Contract Scanner</p>
      <h1 class="text-4xl md:text-5xl font-bold text-on-surface font-headline mb-4">Check any contract</h1>
      <p class="text-on-surface-variant text-lg">Paste an address. Get a safety verdict. No install needed.</p>
    </div>

    <!-- Input form -->
    <div class="glass-card border border-outline-variant/20 rounded-2xl p-6 mb-8">
      <div class="flex flex-col gap-4">
        <div>
          <label for="contract-address" class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mb-2 block">Contract Address</label>
          <input
            id="contract-address"
            type="text"
            placeholder="0x..."
            spellcheck="false"
            autocomplete="off"
            class="w-full bg-surface-container-lowest/60 border border-outline-variant/30 rounded-xl px-4 py-3 font-mono text-sm text-on-surface placeholder:text-outline focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/30 transition-all"
          />
          <p id="address-error" class="text-error text-xs mt-1.5 hidden"></p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1">
            <label for="chain-select" class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mb-2 block">Chain</label>
            <select
              id="chain-select"
              class="w-full bg-surface-container-lowest/60 border border-outline-variant/30 rounded-xl px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/30 transition-all appearance-none cursor-pointer"
            >
              <option value="1">Ethereum Mainnet</option>
              <option value="8453">Base</option>
              <option value="84532">Base Sepolia</option>
            </select>
          </div>

          <div class="flex items-end">
            <button
              id="scan-btn"
              class="w-full sm:w-auto px-8 py-3 bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-bold rounded-xl text-sm hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:hover:scale-100"
            >
              <span class="material-symbols-outlined text-[18px]">radar</span>
              <span id="scan-btn-text">Scan Contract</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading state -->
    <div id="loading" class="hidden text-center py-16">
      <div class="inline-flex items-center gap-3 px-6 py-3 glass-card border border-outline-variant/20 rounded-xl">
        <div class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
        <span class="text-on-surface-variant text-sm">Scanning contract...</span>
      </div>
    </div>

    <!-- Error state -->
    <div id="error-display" class="hidden glass-card border border-error/30 rounded-2xl p-6 mb-8">
      <div class="flex items-start gap-3">
        <span class="material-symbols-outlined text-error text-xl shrink-0 mt-0.5">error</span>
        <div>
          <h3 class="text-on-surface font-bold font-headline mb-1">Scan failed</h3>
          <p id="error-message" class="text-on-surface-variant text-sm"></p>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="hidden space-y-6">

      <!-- Verdict card -->
      <div id="verdict-card" class="rounded-2xl p-8 border text-center">
        <span id="verdict-icon" class="material-symbols-outlined text-5xl mb-4"></span>
        <h2 id="verdict-text" class="text-2xl font-bold font-headline mb-2"></h2>
        <p id="verdict-desc" class="text-sm mb-4"></p>
        <div class="flex items-center justify-center gap-4">
          <div class="text-center">
            <p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mb-1">Risk Score</p>
            <p id="risk-score" class="text-3xl font-black font-headline"></p>
          </div>
          <div class="w-px h-12 bg-outline-variant/30"></div>
          <div class="text-center">
            <p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant mb-1">Findings</p>
            <p id="findings-count" class="text-3xl font-black font-headline text-on-surface"></p>
          </div>
        </div>
      </div>

      <!-- Honeypot check -->
      <div id="honeypot-section" class="hidden glass-card border border-outline-variant/20 rounded-2xl p-6">
        <h3 class="text-lg font-bold font-headline text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary">toll</span>
          Token Safety
        </h3>
        <div id="honeypot-result" class="space-y-3"></div>
      </div>

      <!-- Findings list -->
      <div id="findings-section" class="hidden glass-card border border-outline-variant/20 rounded-2xl p-6">
        <h3 class="text-lg font-bold font-headline text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">checklist</span>
          Findings
        </h3>
        <div id="findings-list" class="space-y-3"></div>
      </div>

      <!-- Recommendation -->
      <div id="recommendation-section" class="hidden glass-card border border-outline-variant/20 rounded-2xl p-6">
        <h3 class="text-lg font-bold font-headline text-on-surface mb-3 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary-dim">lightbulb</span>
          Recommendation
        </h3>
        <p id="recommendation-text" class="text-on-surface-variant text-sm leading-relaxed"></p>
      </div>

    </div>
  </main>

  <script>
    const addressInput = document.getElementById("contract-address") as HTMLInputElement;
    const chainSelect = document.getElementById("chain-select") as HTMLSelectElement;
    const scanBtn = document.getElementById("scan-btn") as HTMLButtonElement;
    const scanBtnText = document.getElementById("scan-btn-text") as HTMLSpanElement;
    const addressError = document.getElementById("address-error") as HTMLParagraphElement;
    const loading = document.getElementById("loading") as HTMLDivElement;
    const errorDisplay = document.getElementById("error-display") as HTMLDivElement;
    const errorMessage = document.getElementById("error-message") as HTMLParagraphElement;
    const results = document.getElementById("results") as HTMLDivElement;

    const ADDRESS_RE = /^0x[a-fA-F0-9]{40}$/;

    function showError(msg: string) {
      errorDisplay.classList.remove("hidden");
      errorMessage.textContent = msg;
      results.classList.add("hidden");
      loading.classList.add("hidden");
    }

    function hideAll() {
      errorDisplay.classList.add("hidden");
      results.classList.add("hidden");
      loading.classList.add("hidden");
      addressError.classList.add("hidden");
    }

    function severityColor(severity: string): string {
      switch (severity) {
        case "critical": return "bg-error text-error";
        case "high": return "bg-error/70 text-error";
        case "medium": return "bg-primary-dim text-primary-dim";
        case "low": return "bg-tertiary text-tertiary";
        default: return "bg-outline text-outline";
      }
    }

    function renderVerdict(riskScore: number) {
      const card = document.getElementById("verdict-card")!;
      const icon = document.getElementById("verdict-icon")!;
      const text = document.getElementById("verdict-text")!;
      const desc = document.getElementById("verdict-desc")!;
      const score = document.getElementById("risk-score")!;

      score.textContent = String(riskScore);

      if (riskScore < 20) {
        card.className = "rounded-2xl p-8 border text-center bg-secondary/5 border-secondary/30";
        icon.textContent = "verified_user";
        icon.className = "material-symbols-outlined text-5xl mb-4 text-secondary";
        text.textContent = "Safe";
        text.className = "text-2xl font-bold font-headline mb-2 text-secondary";
        desc.textContent = "No significant risks detected. This contract looks safe to interact with.";
        score.className = "text-3xl font-black font-headline text-secondary";
      } else if (riskScore < 40) {
        card.className = "rounded-2xl p-8 border text-center bg-tertiary/5 border-tertiary/30";
        icon.textContent = "info";
        icon.className = "material-symbols-outlined text-5xl mb-4 text-tertiary";
        text.textContent = "Low Risk";
        text.className = "text-2xl font-bold font-headline mb-2 text-tertiary";
        desc.textContent = "Minor issues found. Likely safe but review the findings below.";
        score.className = "text-3xl font-black font-headline text-tertiary";
      } else if (riskScore < 60) {
        card.className = "rounded-2xl p-8 border text-center bg-primary-dim/5 border-primary-dim/30";
        icon.textContent = "warning";
        icon.className = "material-symbols-outlined text-5xl mb-4 text-primary-dim";
        text.textContent = "Medium Risk";
        text.className = "text-2xl font-bold font-headline mb-2 text-primary-dim";
        desc.textContent = "Notable concerns found. Proceed with caution and review findings carefully.";
        score.className = "text-3xl font-black font-headline text-primary-dim";
      } else if (riskScore < 80) {
        card.className = "rounded-2xl p-8 border text-center bg-error/5 border-error/30";
        icon.textContent = "gpp_maybe";
        icon.className = "material-symbols-outlined text-5xl mb-4 text-error";
        text.textContent = "High Risk";
        text.className = "text-2xl font-bold font-headline mb-2 text-error";
        desc.textContent = "Serious risks detected. Interacting with this contract is not recommended.";
        score.className = "text-3xl font-black font-headline text-error";
      } else {
        card.className = "rounded-2xl p-8 border text-center bg-error/10 border-error/50";
        icon.textContent = "dangerous";
        icon.className = "material-symbols-outlined text-5xl mb-4 text-error";
        text.textContent = "Critical - Do Not Interact";
        text.className = "text-2xl font-bold font-headline mb-2 text-error";
        desc.textContent = "This contract exhibits known exploit patterns or scam mechanics. Do not send funds.";
        score.className = "text-3xl font-black font-headline text-error";
      }
    }

    function renderFindings(findings: Array<{name: string; severity: string; description: string; riskWeight: number}>) {
      const section = document.getElementById("findings-section")!;
      const list = document.getElementById("findings-list")!;
      const count = document.getElementById("findings-count")!;

      count.textContent = String(findings.length);

      if (findings.length === 0) {
        section.classList.add("hidden");
        return;
      }

      section.classList.remove("hidden");
      list.innerHTML = findings.map(f => `
        <div class="flex items-start gap-3 p-3 rounded-xl bg-surface-container-lowest/40">
          <span class="w-1.5 h-1.5 rounded-full ${severityColor(f.severity).split(" ")[0]} shrink-0 mt-2"></span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-sm font-medium text-on-surface">${f.name}</span>
              <span class="text-[10px] font-label uppercase tracking-widest ${severityColor(f.severity).split(" ")[1]}">${f.severity}</span>
            </div>
            <p class="text-xs text-on-surface-variant">${f.description}</p>
          </div>
        </div>
      `).join("");
    }

    function renderHoneypot(data: {sellability: {canSell: boolean; error?: string}; overallAssessment: string}) {
      const section = document.getElementById("honeypot-section")!;
      const result = document.getElementById("honeypot-result")!;

      section.classList.remove("hidden");

      const canSell = data.sellability.canSell;
      const assessment = data.overallAssessment;

      result.innerHTML = `
        <div class="flex items-center gap-3 p-3 rounded-xl bg-surface-container-lowest/40">
          <span class="material-symbols-outlined text-lg ${canSell ? "text-secondary" : "text-error"}">${canSell ? "check_circle" : "cancel"}</span>
          <div>
            <span class="text-sm font-medium text-on-surface">${canSell ? "Token is sellable" : "Token may not be sellable"}</span>
            <p class="text-xs text-on-surface-variant">${canSell ? "Sell simulation succeeded - no honeypot detected" : (data.sellability.error || "Sell simulation failed - possible honeypot")}</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 rounded-xl bg-surface-container-lowest/40">
          <span class="material-symbols-outlined text-lg ${assessment === "LIKELY_SAFE" ? "text-secondary" : "text-error"}">${assessment === "LIKELY_SAFE" ? "thumb_up" : "thumb_down"}</span>
          <div>
            <span class="text-sm font-medium text-on-surface">Overall: ${assessment === "LIKELY_SAFE" ? "Likely Safe" : "Potentially Dangerous"}</span>
          </div>
        </div>
      `;
    }

    async function runScan() {
      const address = addressInput.value.trim();
      const chainId = Number(chainSelect.value);

      // Validate
      if (!address) {
        addressError.textContent = "Please enter a contract address.";
        addressError.classList.remove("hidden");
        return;
      }
      if (!ADDRESS_RE.test(address)) {
        addressError.textContent = "Invalid address. Must be 0x followed by 40 hex characters.";
        addressError.classList.remove("hidden");
        return;
      }

      hideAll();
      loading.classList.remove("hidden");
      scanBtn.disabled = true;
      scanBtnText.textContent = "Scanning...";

      try {
        // Run scan and check-token in parallel
        const [scanRes, tokenRes] = await Promise.allSettled([
          fetch("/api/scan", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ contractAddress: address, chainId }),
          }),
          fetch("/api/check-token", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ tokenAddress: address, chainId }),
          }),
        ]);

        // Process scan result
        if (scanRes.status === "rejected") {
          showError("Network error running contract scan. Please try again.");
          return;
        }

        const scanData = await scanRes.value.json();
        if (scanData.error) {
          showError(scanData.error + (scanData.details ? `: ${scanData.details}` : ""));
          return;
        }

        // Show results
        loading.classList.add("hidden");
        results.classList.remove("hidden");

        renderVerdict(scanData.riskScore ?? 0);
        renderFindings(scanData.findings ?? []);

        // Recommendation
        if (scanData.recommendation) {
          document.getElementById("recommendation-section")!.classList.remove("hidden");
          document.getElementById("recommendation-text")!.textContent = scanData.recommendation;
        }

        // Process token result
        if (tokenRes.status === "fulfilled") {
          const tokenData = await tokenRes.value.json();
          if (!tokenData.error && tokenData.sellability) {
            renderHoneypot(tokenData);
          }
        }

      } catch (err) {
        showError("Something went wrong. Check your connection and try again.");
      } finally {
        scanBtn.disabled = false;
        scanBtnText.textContent = "Scan Contract";
      }
    }

    scanBtn.addEventListener("click", runScan);
    addressInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") runScan();
    });
    addressInput.addEventListener("input", () => {
      addressError.classList.add("hidden");
    });
  </script>
</Layout>

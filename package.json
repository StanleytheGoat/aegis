{
  "name": "aegis-defi",
  "version": "0.2.0",
  "description": "A safety layer for autonomous DeFi agents - MCP server + smart contracts that simulate, scan, and protect on-chain transactions before execution.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aegis": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.ts",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "test": "vitest run",
    "demo": "tsx demo/catch-honeypot.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@uniswap/v4-core": "^1.0.2",
    "@uniswap/v4-periphery": "^1.0.3",
    "ethers": "^6.13.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.0.0",
    "hardhat": "^2.22.17",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "defi",
    "security",
    "mcp",
    "ai-agents",
    "ethereum",
    "uniswap",
    "safety"
  ],
  "license": "MIT"
}

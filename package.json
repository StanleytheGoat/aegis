{
  "name": "aegis-defi",
  "version": "0.5.0",
  "description": "A safety layer for autonomous DeFi agents - MCP server + smart contracts that simulate, scan, and protect on-chain transactions before execution.",
  "type": "module",
  "main": "dist/risk-engine/index.js",
  "types": "dist/risk-engine/index.d.ts",
  "bin": {
    "aegis": "dist/index.js",
    "aegis-defi": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/risk-engine/index.d.ts",
      "default": "./dist/risk-engine/index.js"
    },
    "./server": {
      "types": "./dist/mcp-server/index.d.ts",
      "default": "./dist/mcp-server/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "test": "vitest run",
    "demo": "tsx demo/catch-honeypot.ts",
    "prepare": "husky",
    "prepublishOnly": "tsc",
    "build:site": "astro build",
    "dev:site": "astro dev",
    "preview:site": "astro preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@uniswap/v4-core": "^1.0.0",
    "@uniswap/v4-periphery": "^1.0.0",
    "astro": "^5.18.0",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.17",
    "husky": "^9.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "defi",
    "security",
    "mcp",
    "ai-agents",
    "ethereum",
    "uniswap",
    "safety"
  ],
  "license": "MIT"
}
